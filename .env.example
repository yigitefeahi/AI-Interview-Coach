# AI Interview Coach — Environment template (root)
# Copy values into backend/.env and frontend/.env.local
# NEVER commit real secrets to Git.

# ─── Backend (backend/.env) ───────────────────────────────────────────

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_MINUTES=10080
AUTH_COOKIE_SECURE=false
RATE_LIMIT_PERSIST=true
REDIS_URL=

DATABASE_URL=sqlite:///./test.db
# Production (Render): PostgreSQL connection string from host

OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
TTS_MODEL=gpt-4o-mini-tts
EMBEDDING_MODEL=text-embedding-3-small

CHROMA_DIR=./chroma
CORS_ORIGINS=http://localhost:3000

CV_LLM_ENRICH=false
CV_LLM_SCREENING=true
CV_SCREENING_MODEL=

# ─── Frontend (frontend/.env.local) ───────────────────────────────────

NEXT_PUBLIC_API_BASE=http://localhost:8000
# Production example:
# NEXT_PUBLIC_API_BASE=https://your-backend.onrender.com
# CORS_ORIGINS on backend must include your frontend URL
